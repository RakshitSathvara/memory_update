<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">


    <!-- Background -->
    <item android:id="@+id/main_card">
        <shape >
            <solid android:color="@color/card_background" />
            <corners android:bottomLeftRadius="2dp"
                android:bottomRightRadius="2dp" />
        </shape>
    </item>

    <item android:gravity="bottom"  >
        <shape >
            <padding android:top="0dp" android:right="0dp"  android:left="0dp" />
            <gradient android:startColor="@color/card_shadow_2"  android:endColor="@android:color/transparent" android:angle="270"/>
            <corners android:bottomLeftRadius="2dp"
                android:bottomRightRadius="2dp" />
            <size android:height="5dp"/>
        </shape>
    </item>


</layer-list>